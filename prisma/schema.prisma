generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TECH
  CLIENT
}

model User {
  id                      String       @id @default(cuid())
  name                    String
  email                   String       @unique
  passwordHash            String
  role                    Role         @default(TECH)
  emailVerified           Boolean      @default(false)
  verificationToken       String?      @unique
  verificationTokenExpiry DateTime?
  passwordResetToken      String?      @unique
  passwordResetExpiry     DateTime?
  createdAt               DateTime     @default(now())
  clients                 UserClient[]
}

model Client {
  id            String       @id @default(cuid())
  name          String
  tacticalRmmId  String?      @unique
  address        String?
  phone         String?
  email         String?
  logoPath      String?
  notes         String?
  isHistorical   Boolean      @default(false)
  noSync         Boolean      @default(false)
  billingPeriod  String       @default("monthly")
  createdAt      DateTime     @default(now())
  users         UserClient[]
  contacts      Contact[]
  equipment          Equipment[]
  licenses           License[]
  personnelMovements PersonnelMovement[]
  m365Tenants       M365Tenant[]
  nextcloudServices NextcloudService[]
  voipServices      VoipService[]
  registrars        Registrar[]
  sslCertificates   SslCertificate[]
  hostings          Hosting[]
  registrarConfigs  RegistrarConfig[]
  sites             Site[]
}

model UserClient {
  userId   String
  clientId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([userId, clientId])
}

model Contact {
  id           String   @id @default(cuid())
  clientId     String
  siteId       String?
  firstName    String
  lastName     String
  email        String?
  phone        String?
  role         String?
  notes        String?
  isHistorical Boolean  @default(false)
  noSync       Boolean  @default(false)
  visible      Boolean  @default(true)
  zammadUserId Int?     @unique
  createdAt    DateTime    @default(now())
  client       Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  site         Site?       @relation(fields: [siteId], references: [id], onDelete: SetNull)
  equipment    Equipment[]
}

model Equipment {
  id               String    @id @default(cuid())
  clientId         String
  siteId           String?
  type             String
  operatingSystem  String?
  brand            String?
  model            String?
  serialNumber     String?
  ipAddress        String?
  ipType           String?
  purchaseDate     DateTime?
  warrantyDuration String?
  photoPath        String?
  assignedToId     String?
  notes            String?
  noSync           Boolean   @default(false)
  rmmAgentId       String?   @unique
  createdAt        DateTime  @default(now())
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  site             Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  assignedTo       Contact?  @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
}

model PersonnelMovement {
  id               String   @id @default(cuid())
  clientId         String
  type             String   // "ENTREE" | "SORTIE"
  entryType        String?  // "EMPLOI" | "STAGE" (ENTREE only)
  internshipMonths Int?     // duration in months (STAGE only)
  firstName        String
  lastName         String
  role             String?
  mobile           String?
  email            String?
  accessVPN        Boolean  @default(false)
  accessServer     Boolean  @default(false)
  status           String   @default("EN_ATTENTE") // "EN_ATTENTE" | "ACTIF" | "TERMINE"
  date             DateTime
  notes            String?
  createdAt        DateTime @default(now())
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model License {
  id         String    @id @default(cuid())
  clientId   String
  name       String
  publisher  String?
  expiryDate DateTime?
  seats      Int?
  notes      String?
  createdAt  DateTime  @default(now())
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model M365Tenant {
  id                String           @id @default(cuid())
  clientId          String
  tenantId          String?
  displayName       String
  azureClientId     String?
  azureClientSecret String?
  lastSyncAt        DateTime?
  notes             String?
  createdAt         DateTime         @default(now())
  client            Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  domains           M365Domain[]
  accounts          M365Account[]
  licenseSkus       M365LicenseSku[]
}

model M365LicenseSku {
  id            String     @id @default(cuid())
  tenantId      String
  skuId         String
  skuPartNumber String
  consumed      Int        @default(0)
  total         Int        @default(0)
  updatedAt     DateTime   @updatedAt
  tenant        M365Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, skuId])
}

model M365Domain {
  id        String     @id @default(cuid())
  tenantId  String
  domain    String
  isDefault Boolean    @default(false)
  notes     String?
  createdAt DateTime   @default(now())
  tenant    M365Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model M365Account {
  id                String     @id @default(cuid())
  tenantId          String
  graphId           String?
  displayName       String
  userPrincipalName String
  jobTitle          String?
  licensed          Boolean    @default(true)
  licenseType       String?
  licenseExpiry     DateTime?
  accountEnabled    Boolean    @default(true)
  notes             String?
  m365CreatedAt     DateTime?
  createdAt         DateTime   @default(now())
  tenant            M365Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userPrincipalName])
}

model NextcloudService {
  id        String            @id @default(cuid())
  clientId  String
  name      String
  notes     String?
  createdAt DateTime          @default(now())
  client    Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  servers   NextcloudServer[]
}

model NextcloudServer {
  id           String           @id @default(cuid())
  serviceId    String
  url          String
  version      String?
  adminUser     String?
  adminPassword String?
  storageTotal  String?
  userCount     Int?
  notes        String?
  createdAt    DateTime         @default(now())
  service      NextcloudService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model VoipService {
  id         String          @id @default(cuid())
  clientId   String
  name       String
  provider   String?
  notes      String?
  createdAt  DateTime        @default(now())
  client     Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  equipment  VoipEquipment[]
  trunks     VoipTrunk[]
  extensions VoipExtension[]
}

model VoipEquipment {
  id         String      @id @default(cuid())
  serviceId  String
  type       String
  brand      String?
  model      String?
  macAddress String?
  ipAddress  String?
  notes      String?
  createdAt  DateTime    @default(now())
  service    VoipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model VoipTrunk {
  id        String      @id @default(cuid())
  serviceId String
  name      String
  provider  String?
  sipServer String?
  sipUser   String?
  channels  Int?
  notes     String?
  createdAt DateTime    @default(now())
  service   VoipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model VoipExtension {
  id        String      @id @default(cuid())
  serviceId String
  number    String
  name      String?
  type      String?
  device    String?
  notes     String?
  createdAt DateTime    @default(now())
  service   VoipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

// ── DNS / Certificats / Hébergement ───────────────────────────────────────────

model Registrar {
  id        String    @id @default(cuid())
  clientId  String
  name      String
  notes     String?
  createdAt DateTime  @default(now())
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dnsZones  DnsZone[]
}

model DnsZone {
  id               String      @id @default(cuid())
  registrarId      String
  domain           String
  nameservers      String?
  registrationDate DateTime?
  expiryDate       DateTime?
  autoRenew        Boolean     @default(false)
  source           String      @default("manual")
  ovhZoneName      String?
  notes            String?
  createdAt        DateTime    @default(now())
  registrar        Registrar   @relation(fields: [registrarId], references: [id], onDelete: Cascade)
  records          DnsRecord[]

  @@unique([ovhZoneName, registrarId])
}

model DnsRecord {
  id        String   @id @default(cuid())
  zoneId    String
  type      String
  name      String
  value     String
  ttl       Int?
  priority  Int?
  notes     String?
  createdAt DateTime @default(now())
  zone      DnsZone  @relation(fields: [zoneId], references: [id], onDelete: Cascade)
}

model SslCertificate {
  id         String    @id @default(cuid())
  clientId   String
  domain     String
  issuer     String?
  type       String?
  issuedDate DateTime?
  expiryDate DateTime?
  autoRenew  Boolean   @default(false)
  notes      String?
  createdAt  DateTime  @default(now())
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Hosting {
  id          String    @id @default(cuid())
  clientId    String
  name        String
  type        String?
  provider    String?
  url         String?
  ipAddress   String?
  plan        String?
  renewalDate DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ── Sites client ─────────────────────────────────────────────────────────────

model Site {
  id             String   @id @default(cuid())
  clientId       String
  name           String
  address        String?
  city           String?
  postalCode     String?
  country        String?  @default("France")
  phone          String?
  email          String?
  digicode1      String?
  digicode2      String?
  interphone     String?
  etage          String?
  heureOuverture String?
  heureFermeture String?
  isHeadquarters Boolean  @default(false)
  isDefault      Boolean  @default(false)
  noSync         Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  equipment      Equipment[]
}

// ── Registrar / DNS provider config (OVH, Gandi, LWS) ───────────────────────
// provider   = "ovh" | "gandi" | "lws"
// login      = OVH endpoint (ovh-eu) | LWS client ID | unused for Gandi
// apiKey     = OVH App Key (plaintext) | unused for Gandi/LWS
// apiSecret  = OVH App Secret (encrypted) | unused for Gandi/LWS
// apiToken   = OVH Consumer Key (enc) | Gandi API key (enc) | LWS API key (enc)
// extra      = JSON — LWS: {"domains":["lsiparis.fr",...]}
model RegistrarConfig {
  id         String    @id @default(cuid())
  clientId   String
  provider   String
  login      String?
  apiKey     String?
  apiSecret  String?
  apiToken   String?
  extra      String?
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, provider])
}
