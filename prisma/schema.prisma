generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TECH
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         Role         @default(TECH)
  createdAt    DateTime     @default(now())
  clients      UserClient[]
}

model Client {
  id            String       @id @default(cuid())
  name          String
  tacticalRmmId String?      @unique
  address       String?
  phone         String?
  email         String?
  notes         String?
  createdAt     DateTime     @default(now())
  users         UserClient[]
  contacts      Contact[]
  equipment     Equipment[]
  licenses      License[]
  m365Tenants       M365Tenant[]
  nextcloudServices NextcloudService[]
  voipServices      VoipService[]
}

model UserClient {
  userId   String
  clientId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([userId, clientId])
}

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  firstName String
  lastName  String
  email     String?
  phone     String?
  role      String?
  notes     String?
  createdAt DateTime    @default(now())
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  equipment Equipment[]
}

model Equipment {
  id               String    @id @default(cuid())
  clientId         String
  type             String
  operatingSystem  String?
  brand            String?
  model            String?
  serialNumber     String?
  ipAddress        String?
  ipType           String?
  purchaseDate     DateTime?
  warrantyDuration String?
  photoPath        String?
  assignedToId     String?
  notes            String?
  createdAt        DateTime  @default(now())
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedTo       Contact?  @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
}

model License {
  id         String    @id @default(cuid())
  clientId   String
  name       String
  publisher  String?
  expiryDate DateTime?
  seats      Int?
  notes      String?
  createdAt  DateTime  @default(now())
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model M365Tenant {
  id          String        @id @default(cuid())
  clientId    String
  tenantId    String?
  displayName String
  notes       String?
  createdAt   DateTime      @default(now())
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  domains     M365Domain[]
  accounts    M365Account[]
}

model M365Domain {
  id        String     @id @default(cuid())
  tenantId  String
  domain    String
  isDefault Boolean    @default(false)
  notes     String?
  createdAt DateTime   @default(now())
  tenant    M365Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model M365Account {
  id                String     @id @default(cuid())
  tenantId          String
  displayName       String
  userPrincipalName String
  jobTitle          String?
  licensed          Boolean    @default(true)
  notes             String?
  createdAt         DateTime   @default(now())
  tenant            M365Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model NextcloudService {
  id        String            @id @default(cuid())
  clientId  String
  name      String
  notes     String?
  createdAt DateTime          @default(now())
  client    Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  servers   NextcloudServer[]
}

model NextcloudServer {
  id           String           @id @default(cuid())
  serviceId    String
  url          String
  version      String?
  adminUser    String?
  storageTotal String?
  userCount    Int?
  notes        String?
  createdAt    DateTime         @default(now())
  service      NextcloudService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model VoipService {
  id         String          @id @default(cuid())
  clientId   String
  name       String
  provider   String?
  notes      String?
  createdAt  DateTime        @default(now())
  client     Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  equipment  VoipEquipment[]
  trunks     VoipTrunk[]
  extensions VoipExtension[]
}

model VoipEquipment {
  id         String      @id @default(cuid())
  serviceId  String
  type       String
  brand      String?
  model      String?
  macAddress String?
  ipAddress  String?
  notes      String?
  createdAt  DateTime    @default(now())
  service    VoipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model VoipTrunk {
  id        String      @id @default(cuid())
  serviceId String
  name      String
  provider  String?
  sipServer String?
  sipUser   String?
  channels  Int?
  notes     String?
  createdAt DateTime    @default(now())
  service   VoipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model VoipExtension {
  id        String      @id @default(cuid())
  serviceId String
  number    String
  name      String?
  type      String?
  device    String?
  notes     String?
  createdAt DateTime    @default(now())
  service   VoipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}
