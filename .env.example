# ── Base de données ─────────────────────────────────────────────────────────────
# Mot de passe PostgreSQL (choisir un mot de passe fort)
POSTGRES_PASSWORD=changez-moi

# URL de connexion (générée automatiquement par docker-compose — ne pas modifier)
DATABASE_URL="postgresql://lsi:changez-moi@postgres:5432/lsi_portal?schema=public"

# ── Next.js Auth ────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=

# URL publique de l'application (avec https:// en prod)
NEXTAUTH_URL=https://thor.lsi-maintenance.fr

# ── Chiffrement ─────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32  (exactement 64 caractères hex)
ENCRYPTION_KEY=

# ── Cron (tâches planifiées) ────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 24
CRON_SECRET=

# ── Déploiement Portainer ───────────────────────────────────────────────────────
# Nom de domaine (utilisé par nginx + Let's Encrypt)
DOMAIN=thor.lsi-maintenance.fr

# Email Let's Encrypt (notifications d'expiration)
LETSENCRYPT_EMAIL=admin@lsi-maintenance.fr

# ── Email (Mailgun) ─────────────────────────────────────────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.lsi-maintenance.fr
MAILGUN_FROM=LSI Maintenance <noreply@mg.lsi-maintenance.fr>
LSI_NOTIFY_EMAIL=contact@lsi-maintenance.fr

# ── Desk365 (ticketing) ─────────────────────────────────────────────────────────
# Sous-domaine de votre compte Desk365 (ex: lsi pour lsi.desk365.io)
DESK365_SUBDOMAIN=lsi-maintenance
# Clé API Desk365 (Paramètres → API → Créer une clé API)
DESK365_API_KEY=

# ── Wasabi (stockage S3) ────────────────────────────────────────────────────────
# Identifiants du compte Wasabi (Console → Access Keys)
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
# Endpoint optionnel — par défaut https://s3.wasabisys.com (us-east-1)
# Exemples : https://s3.eu-central-1.wasabisys.com
#            https://s3.ap-northeast-1.wasabisys.com
# WASABI_ENDPOINT=

# ── Comet Backup (monitoring sauvegardes) ───────────────────────────────────────
# URL du serveur Comet (ex: https://backup.lsi-maintenance.fr)
COMET_SERVER_URL=
# Identifiants admin du serveur Comet
COMET_ADMIN_USER=
COMET_ADMIN_PASS=

# ── Axonaut (CRM / facturation) ─────────────────────────────────────────────────
# Clé API Axonaut (Mon compte → API → Clé API)
AXONAUT_API_KEY=

# ── DocuSeal (signature électronique) ───────────────────────────────────────────
# Clé API DocuSeal (console.docuseal.eu → API)
DOCUSEAL_API_KEY=
# URL API — EU Cloud par défaut (ou https://api.docuseal.com pour Global)
DOCUSEAL_API_URL=https://api.docuseal.eu

# ── Tactical RMM (supervision) ──────────────────────────────────────────────────
# URL de l'API RMM (ex: https://api.mon-rmm.fr) — pas l'interface web
RMM_BASE_URL=
# Clé API Tactical RMM
RMM_API_KEY=

# ── Dev local uniquement ────────────────────────────────────────────────────────
APP_PORT=3000
