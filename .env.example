# ── Base de données ────────────────────────────────────────────────────────────
# Mot de passe PostgreSQL (choisir un mot de passe fort)
POSTGRES_PASSWORD=changez-moi

# URL de connexion (générée automatiquement par docker-compose — ne pas modifier)
DATABASE_URL="postgresql://lsi:changez-moi@postgres:5432/lsi_portal?schema=public"

# ── Next.js Auth ───────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=

# URL publique de l'application (avec https:// en prod)
NEXTAUTH_URL=https://thor.lsi-maintenance.fr

# ── Chiffrement (clé API RMM) ──────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32  (exactement 64 caractères hex)
ENCRYPTION_KEY=

# ── Déploiement Portainer ──────────────────────────────────────────────────────
# Nom de domaine (utilisé par nginx + Let's Encrypt)
DOMAIN=thor.lsi-maintenance.fr

# Email Let's Encrypt (notifications d'expiration)
LETSENCRYPT_EMAIL=admin@lsi-maintenance.fr

# ── Email (Mailgun) ────────────────────────────────────────────────────────────
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.lsi-maintenance.fr
MAILGUN_FROM=LSI Maintenance <noreply@mg.lsi-maintenance.fr>
LSI_NOTIFY_EMAIL=contact@lsi-maintenance.fr

# ── Cron (tâches planifiées) ───────────────────────────────────────────────────
# Générer avec : openssl rand -hex 24
CRON_SECRET=1384044c4bfb5624e29653233307f258f9e5c0ef6e243f6c

# ── Dev local uniquement ───────────────────────────────────────────────────────
# Port exposé en local (docker-compose.yml)
APP_PORT=3000
